# Flask UI service
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=1
FLASK_APP=run_flask
SECRET_KEY=change-me-in-production

# FastAPI service
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=1

# Shared
ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=mavan

# Auth
AUTH_MODE=dev
DEV_USERNAME=username
# JWT (when AUTH_MODE=jwt)
JWT_SECRET_KEY=change-me-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
LOGIN_USERNAME=username
LOGIN_PASSWORD=your-password-here

# File uploads
FILESYSTEM_PATH=./data/uploads
MAX_FILES_PER_REQUEST=10
MAX_FILE_SIZE_BYTES=10485760
# Allowed file types - comprehensive list supporting all document, image, audio, and video formats
# Text: .txt, .md, .csv, .json, .xml, .html
# Documents: .pdf, .docx, .doc, .xlsx, .xls, .pptx, .ppt
# Images: .jpg, .jpeg, .png, .gif, .bmp, .webp, .tiff, .tif
# Audio: .mp3, .wav, .m4a, .flac, .ogg, .aac
# Video: .mp4, .avi, .mov, .mkv, .webm, .flv, .wmv
ALLOWED_FILE_TYPES=text/plain,text/markdown,text/csv,application/json,application/xml,text/xml,text/html,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.ms-powerpoint,image/jpeg,image/png,image/gif,image/bmp,image/webp,image/tiff,audio/mpeg,audio/wav,audio/x-m4a,audio/flac,audio/ogg,audio/aac,video/mp4,video/x-msvideo,video/quicktime,video/x-matroska,video/webm,video/x-flv,video/x-ms-wmv

#LLM — общие настройки
LLM_PROVIDER=mock
# mock | openai | anthropic | gemini | mistral | deepseek | huggingface | github_models | ollama | llama_local
# defaults по capability (пусто = LLM_PROVIDER)
LLM_CHAT_PROVIDER=mock
LLM_EMBED_PROVIDER=mock
LLM_RERANK_PROVIDER=mock
LLM_OCR_PROVIDER=mock
LLM_SPEECH_PROVIDER=mock

# модели (опционально, per capability) # пусто = preset провайдера
LLM_CHAT_MODEL=
LLM_EMBED_MODEL=
LLM_RERANK_MODEL=
LLM_SPEECH_MODEL=whisper-1

LLM_DEFAULT_MAX_TOKENS=1024
LLM_DEFAULT_TEMPERATURE=0.7

# --- OpenAI ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic (нативный API, не OpenAI-compatible) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Google AI Studio (Gemini, бесплатный tier) ---
GOOGLE_API_KEY=
GEMINI_API_KEY=
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Cohere ---
COHERE_API_KEY=
# COHERE_RERANK_MODEL=rerank-english-v3.0

# --- Mistral ---
MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL=mistral-small-latest
# MISTRAL_EMBED_MODEL=mistral-embed

# --- DeepSeek ---
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_EMBED_MODEL=deepseek-embed

# --- Hugging Face Inference ---
HF_TOKEN=
# HF_BASE_URL=https://router.huggingface.co/v1
# HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- GitHub Models (не GitHub Copilot IDE!) ---
GITHUB_TOKEN=
# GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
# GITHUB_MODELS_MODEL=openai/gpt-4o

# --- Ollama (HTTP, OpenAI-compatible) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Локальная Llama (без интернета после загрузки) ---
LLAMA_CKPT_DIR=../Llama3.2-1B-Instruct
LLAMA_MAX_SEQ_LEN=1024
LLAMA_MAX_BATCH_SIZE=1
LLAMA_MODEL_PARALLEL_SIZE=1
LLAMA_MAX_GEN_LEN=256
LLAMA_MAX_DIALOG_LENGTH=1024
# LLAMA_MODEL=Llama3.2-1B-Instruct

#------------------------------------------RAG----------------------

# RAG
RAG_RETRIEVER=hybrid
RAG_DATA_DIR=./data/notes
RAG_VECTOR_INDEX_PATH=./.rag/vector_index
RAG_EVAL_DIR=./data/eval
RAG_CONTEXT_MAX_CHARS=8000
RAG_MIN_SCORE=0.0
RAG_MIN_RELATIVE_SCORE=0.8
RAG_RERANK_ENABLED=false
RAG_FETCH_K=20
RAG_RRF_K=60

# Domain pipeline
DOMAIN_MODEL_DIR=./data/domain_models
INGEST_CACHE_TTL_HOURS=24
QUALITY_PROVIDERS=gemini,openai,mistral
FORECAST_PROVIDERS=gemini,openai,mistral
QUALITY_TIMEOUT_SEC=60
FORECAST_TIMEOUT_SEC=60
QUALITY_CYCLE_MAX=5
QUALITY_CREDIBILITY_MIN=70
QUALITY_COMPLETENESS_MIN=60
QUALITY_DEPTH_MIN=55
QUALITY_TERMINOLOGY_MIN=60
QUALITY_COHERENCE_MIN=65
QUALITY_MISUNDERSTANDING_MAX=40
TRAIN_MIN_SAMPLES=50
TRAIN_MIN_UNIQUE_STATES=15
TRAIN_MIN_UNIQUE_ACTIONS=5
TRAIN_MIN_AVG_QUALITY=70
TRAIN_REPLAY_RATIO=0.3
GOOGLE_SEARCH_API_KEY=<your_serper_key>
GOOGLE_SEARCH_URL=https://google.serper.dev/search

# Domain model architecture (optional — defaults shown)
DOMAIN_MODEL_D_MODEL=256
DOMAIN_MODEL_N_LAYERS=2
DOMAIN_MODEL_N_HEADS=4
DOMAIN_MODEL_FFN=512
DOMAIN_MODEL_VOCAB=8000
DOMAIN_MODEL_EPOCHS=3
DOMAIN_MODEL_BATCH=8

# Capstone security / eval
AGENT_PYTHON_TOOL=false
EVAL_LLM_SLEEP_SEC=6
GUARD_MAX_CONTEXT_LEN=4000
GUARD_MAX_ACTIONS=20