# Flask UI service
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=1
FLASK_APP=run_flask
SECRET_KEY=change-me-in-production

# FastAPI service
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=1

# Shared
ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=mavan

# Auth
AUTH_MODE=dev
DEV_USERNAME=username
# JWT (when AUTH_MODE=jwt)
JWT_SECRET_KEY=change-me-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
LOGIN_USERNAME=username
LOGIN_PASSWORD=your-password-here

# File uploads
FILESYSTEM_PATH=./data/uploads
MAX_FILES_PER_REQUEST=10
MAX_FILE_SIZE_BYTES=10485760
# Allowed file types - comprehensive list supporting all document, image, audio, and video formats
# Text: .txt, .md, .csv, .json, .xml, .html
# Documents: .pdf, .docx, .doc, .xlsx, .xls, .pptx, .ppt
# Images: .jpg, .jpeg, .png, .gif, .bmp, .webp, .tiff, .tif
# Audio: .mp3, .wav, .m4a, .flac, .ogg, .aac
# Video: .mp4, .avi, .mov, .mkv, .webm, .flv, .wmv
ALLOWED_FILE_TYPES=text/plain,text/markdown,text/csv,application/json,application/xml,text/xml,text/html,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.ms-powerpoint,image/jpeg,image/png,image/gif,image/bmp,image/webp,image/tiff,audio/mpeg,audio/wav,audio/x-m4a,audio/flac,audio/ogg,audio/aac,video/mp4,video/x-msvideo,video/quicktime,video/x-matroska,video/webm,video/x-flv,video/x-ms-wmv

#LLM
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434/v1
GEMINI_API_KEY=
LLM_DEFAULT_MAX_TOKENS=1024
LLM_DEFAULT_TEMPERATURE=0.7